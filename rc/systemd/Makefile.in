SYSTEMD_USER_DIR=@SYSTEMD_USER_DIR@

conf_install:
.if !empty(SYSTEMD_USER_DIR)
	sed -e 's|@BINDIR[@]|@BINDIR@|g' mbimapidle.in > mbimapidle
	install -d -m 0755 @SYSTEMD_USER_DIR@
	install -m 0755 mbimapidle @SYSTEMD_USER_DIR@
	rm -f mbimapidle
.endif

install: ${install} conf_install

.include <bsd.prog.mk>
