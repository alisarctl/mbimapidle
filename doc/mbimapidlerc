# see man 1 mbimapidle for more details

[general]
verbose="true"

[mbox1]
hostname = "hostname1"
password  =  "pass1" # Comment
username = "user1"
# sync command to run on mailbox new messages
# command must be in user $PATH
sync_cmd = "/usr/bin/mbsync -a"
# How much time to wait before renewing IDLE subscription According to RFC
# 2177, a server may consider a client inactive after 30 idle_timeout can be
# between 5 to 29 minutes, default: 10 minutes.
idle_timeout = "10"
# Enable/disable checking server ssl certification
# Default: true
check_certificate="false"
port = "993"
tls_type="ssl"
auth = "plain"

[mbox2]
hostname = "hostname2"
password  =  "pass2" # Comment
username = "user2"
sync_cmd = "/usr/bin/mbsync -a"
idle_timeout = "20"
check_certificate="false"
port = "143"
tls_type = "starttls"
auth = "plain"

[gmail]
hostname = "imap.gmail.com"
pass_cmd  =  "/home/user/bin/renew-token"
username = "user2"
sync_cmd = "/usr/bin/mbsync -a"
port = "993"
check_certificate="true"
auth = "XOAUTH2"

